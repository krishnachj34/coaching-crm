generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              String         @id
  email           String         @unique
  name            String?
  role            String         @default("STAFF") // COUNSELLOR, TEACHER, RECEPTIONIST, LIBRARIAN, ADMIN, SUPER_ADMIN
  permissions     Json?          // JSON object storing toggle rights: { leads: "EDIT", students: "VIEW", ... }
  phone           String?
  active          Boolean        @default(true)
  branchId        String?
  branch          Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Lead {
  id             String    @id @default(uuid())
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name           String
  email          String?
  phone          String
  interest       String?  
  status         String    @default("NEW") 
  notes          String?
  source         String    @default("MANUAL")
  trialStartDate DateTime?
  trialEndDate   DateTime?
  nextFollowUp   DateTime?
  followUpNotes  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  whatsappMessages WhatsAppMessage[]

  @@index([phone])
  @@index([email])
  @@index([status])
}

model Course {
  id          String       @id @default(uuid())
  title       String       @unique
  description String?
  feeAmount   Decimal      @db.Decimal(10, 2)
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Student {
  id               String                   @id @default(uuid())
  branchId         String?
  branch           Branch?                  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name             String
  email            String?                  @unique
  phone            String
  rollNo           String?                  @unique
  address          String?
  parentName       String?
  parentPhone      String?
  photoUrl         String?
  courseEndDate    DateTime?
  installments     String?
  enrollments      Enrollment[]
  batchEnrollments StudentBatchEnrollment[]
  testResults      TestResult[]
  payments         Payment[]
  attendance       Attendance[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  courseId  String
  joinedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model StudentBatchEnrollment {
  id        String   @id @default(uuid())
  studentId String
  batchId   String
  joinedAt  DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([studentId, batchId])
}

model Payment {
  id          String   @id @default(uuid())
  studentId   String
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  amount      Decimal  @db.Decimal(10, 2)
  paymentDate DateTime @default(now())
  status      String   @default("PENDING") 
  notes       String?
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  date      DateTime @db.Date
  status    String   @default("PRESENT") 
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
}

model Teacher {
  id              String         @id @default(uuid())
  name            String
  photoUrl        String?
  phone           String
  email           String         @unique
  address         String?
  qualification   String?
  specialization  String?
  franchise       String         // franchise branch location
  branchId        String?
  branch          Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  joiningDate     DateTime       @default(now())
  employmentType  String         @default("FULL_TIME") // FULL_TIME, PART_TIME, VISITING
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  leaves          TeacherLeave[]
  batches         Batch[]
}

model TeacherLeave {
  id                   String   @id @default(uuid())
  teacherId            String
  startDate            DateTime
  endDate              DateTime
  reason               String
  status               String   @default("PENDING") // PENDING, APPROVED, REJECTED
  substituteTeacherId  String?
  createdAt            DateTime @default(now())
  teacher              Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  icon          String?
  color         String?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subCategories SubCategory[]
  subjects      Subject[]
}

model SubCategory {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  batches    Batch[]

  @@unique([name, categoryId])
}

model Batch {
  id            String                   @id @default(uuid())
  name          String                   @unique
  branchId      String?
  branch        Branch?                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  subCategoryId String
  startDate     DateTime
  endDate       DateTime
  days          String
  timing        String
  teacherId     String
  maxCapacity   Int
  feeAmount     Decimal                  @db.Decimal(10, 2)
  active        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  subCategory   SubCategory              @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  teacher       Teacher                  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments   StudentBatchEnrollment[]
  liveClasses   LiveClass[]
  libraryNotes  LibraryNote[]
  mockTests     MockTest[]
}

model Subject {
  id           String        @id @default(uuid())
  name         String
  categoryId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  questions    Question[]
  libraryNotes LibraryNote[]
}

model Question {
  id             String   @id @default(uuid())
  subjectId      String
  topic          String
  difficulty     String   @default("MEDIUM") // EASY, MEDIUM, HARD
  type           String   @default("MCQ") // MCQ, FILL_IN_THE_BLANK, DESCRIPTIVE
  content        String
  answer         String
  explanation    String?
  bandRelevance  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Notice {
  id             String   @id @default(uuid())
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title          String
  content        String
  targetAudience String   @default("ALL") // ALL, BATCH, TEACHERS, ROLE
  targetId       String?
  type           String   @default("GENERAL") // GENERAL, URGENT, HOLIDAY, EXAM_REMINDER
  scheduledAt    DateTime @default(now())
  createdAt      DateTime @default(now())
}

model UpcomingEvent {
  id          String   @id @default(uuid())
  title       String
  type        String   @default("DEMO_CLASS") // DEMO_CLASS, WORKSHOP, WEBINAR
  date        DateTime
  time        String
  instructor  String
  platform    String   @default("OFFLINE") // OFFLINE, ONLINE
  link        String?
  createdAt   DateTime @default(now())
}

model LiveClass {
  id             String   @id @default(uuid())
  title          String
  meetingLink    String
  batchId        String
  date           DateTime
  time           String
  recordingLink  String?
  createdAt      DateTime @default(now())
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model LibraryBook {
  id           String   @id @default(uuid())
  title        String
  author       String
  category     String
  description  String?
  pdfUrl       String
  thumbnailUrl String?
  accessType   String   @default("ALL") // ALL, BATCH, COURSE
  accessId     String?
  createdAt    DateTime @default(now())
}

model LibraryNote {
  id           String   @id @default(uuid())
  title        String
  subjectId    String
  topic        String
  batchId      String
  fileUrl      String
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  batch        Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model OldPaper {
  id          String   @id @default(uuid())
  title       String
  year        Int
  difficulty  String   @default("MEDIUM") // EASY, MEDIUM, HARD
  timeLimit   Int?
  fileUrl     String
  createdAt   DateTime @default(now())
}

model MockTest {
  id               String       @id @default(uuid())
  title            String
  duration         Int
  totalMarks       Int
  passMarks        Int
  batchId          String
  googleFormLink   String?
  googleFormId     String?
  createdAt        DateTime     @default(now())
  batch            Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  results          TestResult[]
}

model TestResult {
  id             String   @id @default(uuid())
  mockTestId     String
  studentId      String
  listeningScore Decimal? @db.Decimal(3, 1)
  readingScore   Decimal? @db.Decimal(3, 1)
  writingScore   Decimal? @db.Decimal(3, 1)
  speakingScore  Decimal? @db.Decimal(3, 1)
  overallScore   Decimal? @db.Decimal(3, 1)
  feedback       String?
  submittedAt    DateTime @default(now())
  mockTest       MockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String?
  phone     String?
  email     String?
  active    Boolean  @default(true)
  
  profiles  Profile[]
  students  Student[]
  leads     Lead[]
  teachers  Teacher[]
  batches   Batch[]
  payments  Payment[]
  notices   Notice[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  userName    String
  userRole    String
  actionType  String   // CREATED, UPDATED, DELETED, COMPLETED_TASK, LOGIN, LOGOUT
  module      String   // LEADS, STUDENTS, ATTENDANCE, STAFF, FEES, EXAMS, ACADEMICS, etc.
  entityId    String?
  description String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model IntegrationSettings {
  id                String   @id @default("meta")
  enabled           Boolean  @default(false)
  accessToken       String?
  pageId            String?
  verifyToken       String   @default("coaching_crm_secret_token")
  fieldsMapping     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WhatsAppChatbotConfig {
  id               String   @id @default("default")
  botEnabled       Boolean  @default(false)
  botMode          String   @default("RULE_BASED") // "RULE_BASED" or "AI"
  systemPrompt     String   @default("You are an AI assistant for an IELTS coaching center. Answer student inquiries about courses, batches, fees, and enrollment. Keep responses concise and friendly.")
  verifyToken      String   @default("whatsapp_bot_verify_token")
  phoneNumberId    String?  // Meta WhatsApp Phone Number ID
  accessToken      String?  // Meta WhatsApp Cloud API Access Token
  welcomeMessage   String   @default("Hello! Welcome to our Coaching Center. How can we help you today? Reply with 'courses', 'batches', or 'agent' to get started.")
  fallbackMessage  String   @default("I didn't quite catch that. You can ask about our 'courses', active 'batches', or type 'agent' to speak with a counselor.")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WhatsAppMessage {
  id          String   @id @default(uuid())
  phone       String   // Sender or receiver phone number
  direction   String   // "INCOMING" or "OUTGOING"
  messageType String   @default("text") // "text", "template", etc.
  content     String   // Message body
  status      String   @default("DELIVERED") // "SENT", "DELIVERED", "READ", "FAILED"
  createdAt   DateTime @default(now())
  leadId      String?  // Optional relation to Lead
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([createdAt])
}
